const drum = sound("[bd hh]*4").bank("RolandTR909")
const clap = sound("[~ cp]*2").bank("RolandTR909")
const bass = note("[~ a1]*2 [~ d2]*2").sound("sawtooth").lpf(800)
const perc = stack(
  n("~ 1 ~  3 ~ ~ 3 1").sound("casio").gain(.30),
  n("~ ~ 0 ~ 0 ~ ~ 0").sound("wind").gain(.30),
  sound("~ siren").gain(.30),
)

stack(
  drum,
  clap,
  perc,
  bass,
  note("[ ~  ~ [a4,c5,e5] ~ ] [ ~  ~ [a4,c5,e5] ~ ] [ ~  ~ [a4,c5,e5] ~ ]  [ ~ ~ ~ [g4,c5,e5]]").sound("gm_piano").delay(0.2).gain(0.95),
  note("  [ a4 ~ ~ a4] [ a4 ~ a4 ~]  [ a4 ~ ~ a4 ]  [ a4 ~ a4 a4 ]*2 ").sound("gm_pizzicato_strings").speed(10).delay(0.2).gain(.80)
).cpm(135/4)   

