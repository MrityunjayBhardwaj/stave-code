const richter_chords =   `<
    [bb2,f3,db4] [ab2,f3,c4] [f2,db3,ab3] [gb2,db3,bb3]
    >/2`

arrange(
  [48, stack(
    richter_chords.euclidRot(3,8,"<0 1 6 0 1 7 0 1 2 0 1 3>").note()
      .s("<triangle>".slow(64))
      .room(0.2)
      ,
    s("bd").euclidRot(3,8,"<0 1 0 0 0 1 0 1 2 0 1 3>").mask("<0 0 1>/16").gain(.6)
       .cutoff(sine2.range2(400,4000).slow(24)).orbit(2)
  ],
  [1, s("bd(3,8,0)").ribbon(1, "<1 1 .5 [.5 .125]>").nudge("<0 0.015>".fast(8))],
)
